# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=railway_db
DB_USER=postgres
DB_PASSWORD=your_postgresql_password_here

# Connection Pool Settings
DB_MIN_CONN=2
DB_MAX_CONN=10
DB_POOL_TIMEOUT=30

# Application Settings
LOG_LEVEL=INFO
TIMEZONE=UTC

# Firebase Configuration (Optional - for backup/cloud features)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_BUCKET=railway-dbms.appspot.com
